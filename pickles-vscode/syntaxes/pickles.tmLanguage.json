{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Pickles",
  "scopeName": "source.pickles",
  "fileTypes": ["pickles"],
  "patterns": [
    { "include": "#variables" },
    { "include": "#string_literals" },
    { "include": "#control_keywords" },
    { "include": "#structural_keywords" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#logical_operators" },
    { "include": "#booleans" },
    { "include": "#numbers" }
  ],
  "repository": {
    "variables": {
      "name": "variable.other.pickles",
      "match": "\"[^\"]*\""
    },
    "string_literals": {
      "name": "string.quoted.single.pickles",
      "match": "'[^']*'"
    },
    "control_keywords": {
      "patterns": [
        {
          "name": "keyword.control.pickles",
          "match": "^Variable Settings"
        },
        {
          "name": "keyword.control.pickles",
          "match": "^Scenario\\b"
        },
        {
          "name": "keyword.control.pickles",
          "match": "^\\s*(Given|When|Then|And)(?= )"
        }
      ]
    },
    "structural_keywords": {
      "patterns": [
        {
          "name": "keyword.other.structural.pickles",
          "match": "\\bis a structure with attributes\\b"
        },
        {
          "name": "keyword.other.structural.pickles",
          "match": "has attributes such that:"
        },
        {
          "name": "keyword.other.structural.pickles",
          "match": "\\belements where each element\\b"
        },
        {
          "name": "keyword.other.structural.pickles",
          "match": "\\bthe system is in its initial state\\b"
        },
        {
          "name": "keyword.other.structural.pickles",
          "match": "such that:"
        },
        {
          "name": "keyword.other.structural.pickles",
          "match": "\\bwith range\\b"
        },
        {
          "name": "keyword.other.structural.pickles",
          "match": "\\barray of\\b"
        },
        {
          "name": "keyword.other.structural.pickles",
          "match": "\\bis an?\\b"
        },
        {
          "name": "keyword.other.structural.pickles",
          "match": "\\bstored\\b"
        },
        {
          "name": "keyword.other.structural.pickles",
          "match": "\\bhas\\b"
        },
        {
          "name": "keyword.other.structural.pickles",
          "match": "\\bis\\b"
        }
      ]
    },
    "types": {
      "name": "storage.type.pickles",
      "match": "\\b(boolean|string|integer|decimal)\\b"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pickles",
          "match": "\\bgreater or equal than\\b"
        },
        {
          "name": "keyword.operator.pickles",
          "match": "\\blower or equal than\\b"
        },
        {
          "name": "keyword.operator.pickles",
          "match": "\\bnot equal to\\b"
        },
        {
          "name": "keyword.operator.pickles",
          "match": "\\bequal to\\b"
        },
        {
          "name": "keyword.operator.pickles",
          "match": "\\bgreater than\\b"
        },
        {
          "name": "keyword.operator.pickles",
          "match": "\\blower than\\b"
        },
        {
          "name": "keyword.operator.pickles",
          "match": "\\bat least\\b"
        },
        {
          "name": "keyword.operator.pickles",
          "match": "\\bat most\\b"
        },
        {
          "name": "keyword.operator.pickles",
          "match": "\\bexactly\\b"
        },
        {
          "name": "keyword.operator.pickles",
          "match": "\\bbetween\\b"
        },
        {
          "name": "keyword.operator.pickles",
          "match": "\\ball\\b"
        },
        {
          "name": "keyword.operator.pickles",
          "match": "\\band\\b"
        }
      ]
    },
    "logical_operators": {
      "name": "keyword.operator.logical.pickles",
      "match": "\\b(AND|OR)\\b"
    },
    "booleans": {
      "name": "constant.language.boolean.pickles",
      "match": "\\b(true|false)\\b"
    },
    "numbers": {
      "name": "constant.numeric.pickles",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    }
  }
}
